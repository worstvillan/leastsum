{
  "rules": {
    ".read": false,
    ".write": false,

    "roomsV2": {
      "$roomCode": {
        "public": {
          ".read": "auth != null && root.child('roomsV2').child($roomCode).child('meta').child('members').child(auth.uid).exists()",
          ".write": false
        },
        "private": {
          "$playerId": {
            ".read": "auth != null && root.child('roomsV2').child($roomCode).child('meta').child('members').child(auth.uid).val() === $playerId",
            ".write": false
          }
        },
        "meta": {
          ".read": false,
          ".write": false
        }
      }
    },

    "roomsV2_engine": {
      ".read": false,
      ".write": false
    },

    "rooms": {
      ".read": false,
      ".write": false
    }
  }
}
